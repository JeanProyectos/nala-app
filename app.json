{
  "expo": {
    "name": "NALA",
    "slug": "nala",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nala.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para videollamadas con veterinarios",
        "NSMicrophoneUsageDescription": "Necesitamos acceso al micrófono para llamadas de voz y videollamadas"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.nala.app",
      "newArchEnabled": true,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "nala",
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Permitir acceso al micrófono para llamadas de voz y videollamadas",
          "cameraPermission": "Permitir acceso a la cámara para videollamadas"
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7ad61771-8843-4944-8dfa-33624e575ffc"
      },
      "apiUrl": "https://nala-api.patasypelos.xyz"
    }
  }
}
